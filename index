<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MeetLoop — Gestión Inteligente de Reuniones</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen">

  <!-- Header / Navbar -->
  <header class="bg-indigo-600 text-white shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <div class="flex items-center space-x-2">
        <i class="fa-solid fa-rotate-right text-2xl text-indigo-200"></i>
        <span class="text-xl font-bold tracking-tight">MeetLoop</span>
      </div>
      <nav class="flex space-x-4">
        <button onclick="switchTab('editor')" id="tab-editor" class="px-3 py-2 rounded-lg bg-indigo-700 font-medium text-sm">
          <i class="fa-solid fa-pen-to-square mr-1"></i> Reunión Activa
        </button>
        <button onclick="switchTab('kanban')" id="tab-kanban" class="px-3 py-2 rounded-lg hover:bg-indigo-500 font-medium text-sm">
          <i class="fa-solid fa-list-check mr-1"></i> Panel de Tareas
        </button>
      </nav>
    </div>
  </header>

  <!-- Main Container -->
  <main class="max-w-7xl mx-auto px-4 py-6">

    <!-- VISTA 1: EDITOR DE REUNIÓN -->
    <section id="view-editor" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Panel Izquierdo: Info & Agenda -->
      <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 lg:col-span-1">
        <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center">
          <i class="fa-regular fa-calendar-check mr-2 text-indigo-600"></i> Datos de la Reunión
        </h2>
        <form id="meeting-form" onsubmit="saveMeetingInfo(event)" class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase mb-1">Título de la Sesión</label>
            <input type="text" id="title" class="w-full border rounded-lg p-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Ej. Sync Semanal - Producto" required>
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase mb-1">Participantes (Emails)</label>
            <input type="text" id="participants" class="w-full border rounded-lg p-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="ana@empresa.com, carlos@empresa.com">
          </div>
          <div>
            <label class="block text-xs font-semibold text-slate-600 uppercase mb-1">Puntos de Agenda</label>
            <textarea id="agenda" rows="3" class="w-full border rounded-lg p-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="- Revisión de avances&#10;- Aprobación de presupuesto"></textarea>
          </div>
          <button type="submit" class="w-full bg-slate-900 text-white text-sm py-2 rounded-lg hover:bg-slate-800 transition">Guardar Agenda</button>
        </form>
      </div>

      <!-- Panel Derecho: Captura en Tiempo Real -->
      <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 lg:col-span-2">
        <h2 class="text-lg font-bold text-slate-900 mb-4 flex items-center">
          <i class="fa-solid fa-bolt mr-2 text-amber-500"></i> Registro en Tiempo Real
        </h2>

        <!-- Formulario Entrada Rápida -->
        <form onsubmit="addItem(event)" class="bg-slate-50 p-4 rounded-lg border border-slate-200 mb-6 space-y-3">
          <div class="flex gap-2">
            <select id="item-type" class="border rounded-lg p-2 text-sm bg-white font-medium text-slate-700">
              <option value="tarea">📌 Tarea</option>
              <option value="acuerdo">🤝 Acuerdo</option>
              <option value="nota">📝 Nota</option>
            </select>
            <input type="text" id="item-text" class="flex-1 border rounded-lg p-2 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" placeholder="Escribe la decisión o tarea..." required>
          </div>
          <div id="task-extra-fields" class="flex gap-2">
            <input type="text" id="item-assignee" class="w-1/2 border rounded-lg p-2 text-sm" placeholder="Responsable (Ej. Ana)">
            <input type="date" id="item-due" class="w-1/2 border rounded-lg p-2 text-sm">
          </div>
          <button type="submit" class="w-full bg-indigo-600 text-white font-medium text-sm py-2 rounded-lg hover:bg-indigo-700 transition">+ Añadir Registro</button>
        </form>

        <!-- Lista de Elementos Registrados -->
        <div class="space-y-3" id="live-items-list">
          <!-- Dinámico -->
        </div>
      </div>
    </section>

    <!-- VISTA 2: KANBAN DE TAREAS -->
    <section id="view-kanban" class="hidden">
      <div class="mb-6 flex justify-between items-center">
        <div>
          <h2 class="text-xl font-bold text-slate-900">Panel de Seguimiento de Acuerdos</h2>
          <p class="text-xs text-slate-500">Visibilidad completa sobre el cumplimiento de compromisos.</p>
        </div>
      </div>

      <!-- Tablero Kanban -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Pendiente -->
        <div class="bg-slate-100 p-4 rounded-xl border border-slate-200">
          <h3 class="font-bold text-slate-700 text-sm mb-3 flex items-center justify-between">
            <span>🔴 Por Hacer</span>
            <span id="count-todo" class="bg-slate-200 text-slate-700 text-xs px-2 py-0.5 rounded-full">0</span>
          </h3>
          <div id="col-todo" class="space-y-2 min-h-[200px]"></div>
        </div>

        <!-- En Progreso -->
        <div class="bg-slate-100 p-4 rounded-xl border border-slate-200">
          <h3 class="font-bold text-slate-700 text-sm mb-3 flex items-center justify-between">
            <span>🟡 En Progreso</span>
            <span id="count-doing" class="bg-slate-200 text-slate-700 text-xs px-2 py-0.5 rounded-full">0</span>
          </h3>
          <div id="col-doing" class="space-y-2 min-h-[200px]"></div>
        </div>

        <!-- Completado -->
        <div class="bg-slate-100 p-4 rounded-xl border border-slate-200">
          <h3 class="font-bold text-slate-700 text-sm mb-3 flex items-center justify-between">
            <span>🟢 Completado</span>
            <span id="count-done" class="bg-slate-200 text-slate-700 text-xs px-2 py-0.5 rounded-full">0</span>
          </h3>
          <div id="col-done" class="space-y-2 min-h-[200px]"></div>
        </div>
      </div>
    </section>

  </main>

  <script>
    // Estado Global (Simulación de Base de Datos en LocalStorage)
    let state = JSON.parse(localStorage.getItem('meetloop_db')) || {
      meeting: { title: '', participants: '', agenda: '' },
      items: []
    };

    function saveState() {
      localStorage.setItem('meetloop_db', JSON.stringify(state));
      render();
    }

    // Toggle de pestañas
    function switchTab(tab) {
      document.getElementById('view-editor').classList.toggle('hidden', tab !== 'editor');
      document.getElementById('view-kanban').classList.toggle('hidden', tab !== 'kanban');
      
      document.getElementById('tab-editor').className = tab === 'editor' ? 'px-3 py-2 rounded-lg bg-indigo-700 font-medium text-sm' : 'px-3 py-2 rounded-lg hover:bg-indigo-500 font-medium text-sm';
      document.getElementById('tab-kanban').className = tab === 'kanban' ? 'px-3 py-2 rounded-lg bg-indigo-700 font-medium text-sm' : 'px-3 py-2 rounded-lg hover:bg-indigo-500 font-medium text-sm';
    }

    // Guardar información general
    function saveMeetingInfo(e) {
      e.preventDefault();
      state.meeting = {
        title: document.getElementById('title').value,
        participants: document.getElementById('participants').value,
        agenda: document.getElementById('agenda').value
      };
      saveState();
      alert('¡Información de la reunión guardada!');
    }

    // Añadir acuerdo / tarea / nota
    function addItem(e) {
      e.preventDefault();
      const type = document.getElementById('item-type').value;
      const text = document.getElementById('item-text').value;
      const assignee = document.getElementById('item-assignee').value;
      const due = document.getElementById('item-due').value;

      const newItem = {
        id: Date.now(),
        type,
        text,
        assignee: type === 'tarea' ? assignee || 'Sin Asignar' : null,
        due: type === 'tarea' ? due || 'Sin fecha' : null,
        status: 'todo' // todo, doing, done
      };

      state.items.push(newItem);
      document.getElementById('item-text').value = '';
      document.getElementById('item-assignee').value = '';
      document.getElementById('item-due').value = '';
      
      saveState();
    }

    // Cambiar estado de tarea
    function moveStatus(id, newStatus) {
      const item = state.items.find(i => i.id === id);
      if (item) {
        item.status = newStatus;
        saveState();
      }
    }

    // Renderizar Interfaz
    function render() {
      // 1. Cargar Formulario
      document.getElementById('title').value = state.meeting.title || '';
      document.getElementById('participants').value = state.meeting.participants || '';
      document.getElementById('agenda').value = state.meeting.agenda || '';

      // 2. Render Live Items
      const liveList = document.getElementById('live-items-list');
      liveList.innerHTML = '';
      state.items.forEach(item => {
        let badgeColor = item.type === 'tarea' ? 'bg-amber-100 text-amber-800' : item.type === 'acuerdo' ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-800';
        let badgeIcon = item.type === 'tarea' ? '📌 Tarea' : item.type === 'acuerdo' ? '🤝 Acuerdo' : '📝 Nota';

        const div = document.createElement('div');
        div.className = 'p-3 border rounded-lg flex justify-between items-start bg-white';
        div.innerHTML = `
          <div>
            <span class="text-xs px-2 py-0.5 rounded-full font-semibold ${badgeColor}">${badgeIcon}</span>
            <p class="text-sm font-medium mt-1 text-slate-800">${item.text}</p>
            ${item.type === 'tarea' ? `<p class="text-xs text-slate-500 mt-1">👤 ${item.assignee} | 📅 ${item.due}</p>` : ''}
          </div>
        `;
        liveList.appendChild(div);
      });

      // 3. Render Kanban
      const tasks = state.items.filter(i => i.type === 'tarea');
      ['todo', 'doing', 'done'].forEach(status => {
        const col = document.getElementById(`col-${status}`);
        col.innerHTML = '';
        const filtered = tasks.filter(t => t.status === status);
        document.getElementById(`count-${status}`).innerText = filtered.length;

        filtered.forEach(t => {
          const card = document.createElement('div');
          card.className = 'bg-white p-3 rounded-lg border border-slate-200 shadow-sm space-y-2';
          card.innerHTML = `
            <p class="text-sm font-semibold text-slate-800">${t.text}</p>
            <div class="flex justify-between items-center text-xs text-slate-500">
              <span>👤 ${t.assignee}</span>
              <span>📅 ${t.due}</span>
            </div>
            <div class="pt-2 border-t flex justify-end gap-1 text-xs">
              ${status !== 'todo' ? `<button onclick="moveStatus(${t.id}, 'todo')" class="px-2 py-1 bg-slate-100 rounded">🔴 Por hacer</button>` : ''}
              ${status !== 'doing' ? `<button onclick="moveStatus(${t.id}, 'doing')" class="px-2 py-1 bg-slate-100 rounded">🟡 En progreso</button>` : ''}
              ${status !== 'done' ? `<button onclick="moveStatus(${t.id}, 'done')" class="px-2 py-1 bg-slate-100 rounded">🟢 Hecho</button>` : ''}
            </div>
          `;
          col.appendChild(card);
        });
      });
    }

    // Inicializar
    render();
  </script>
</body>
</html>
